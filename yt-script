#!/usr/bin/env bash
# yt-script — 유튜브 자막 추출/정리(추출 모드) + 구조화 요약 저장(--save 모드).
#
#   추출:  yt-script <유튜브 URL> [언어코드(기본 ko)]
#          -> {출력}/_transcripts/{날짜}_{제목}_{VID}.txt 생성  ({출력} 기본=소스 형제 summaries/, YT_OUT_DIR 로 변경)
#             (헤더 + 챕터 구간별 본문). stdout 에 "OUTPUT_FILE: <경로>" 마커.
#   저장:  yt-script --save <transcript_path> <domain>   (요약 .md 를 stdin 으로)
#          -> ${YT_OUT_DIR}/{정규화도메인}/{stem}.md 저장.
#             경로 조립·폴더 생성·도메인 정규화는 전부 여기서(결정론적·경로탈출 차단).
#
# 두뇌(요약·도메인 판단)는 Claude Code. 이 스크립트는 추출과 파일쓰기·경로안전만 담당.
set -euo pipefail

# 자기 실제 경로(심링크 해석) — ytclean.py 위치와 기본 출력폴더 계산에 쓴다.
SELF="$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$0" 2>/dev/null || echo "$0")"
SELF_DIR="$(dirname "$SELF")"

# 기본 출력 폴더: 소스 폴더의 형제 'summaries' (예: youtube/yt_summary_agent -> youtube/summaries).
# YT_OUT_DIR 환경변수로 언제든 덮어쓸 수 있다.
OUT_DIR="${YT_OUT_DIR:-$(dirname "$SELF_DIR")/summaries}"

# ytclean.py 는 스크립트 실제 경로 옆에 있다(심링크로 실행돼도 OK).
resolve_clean() {
  echo "$SELF_DIR/ytclean.py"
}

# $1(폴더) 안의 가장 최근 .md(_transcripts 제외) 절대경로를 출력(없으면 빈 문자열).
# stat 으로 mtime 정렬 — find 결과가 비어도 안전(빈 입력 시 cwd 를 뒤지지 않음).
latest_md() {
  find "$1" -type f -name '*.md' -not -path "$1/_transcripts/*" -print0 2>/dev/null \
    | xargs -0 stat -f '%m %N' 2>/dev/null | sort -rn | head -n1 | cut -d' ' -f2-
}

# ──────────────────────────────────────────────────────────────────────────
# 저장 모드:  yt-script --save <transcript_path> <domain>   (.md 본문은 stdin)
# ──────────────────────────────────────────────────────────────────────────
if [ "${1:-}" = "--save" ]; then
  TRANSCRIPT="${2:-}"
  DOMAIN_RAW="${3:-}"
  if [ -z "$TRANSCRIPT" ] || [ -z "$DOMAIN_RAW" ]; then
    echo "사용법: yt-script --save <transcript_path> <domain>   (요약 .md 는 stdin)" >&2
    exit 1
  fi

  # OUT_DIR 도 realpath 로 정규화(macOS /var -> /private/var 등 심링크 차이 흡수)
  TDIR="$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$OUT_DIR/_transcripts")"
  TABS="$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$TRANSCRIPT")"
  case "$TABS" in
    "$TDIR"/*) : ;;  # OUT_DIR/_transcripts/ 내부만 허용
    *) echo "오류: transcript 경로가 $TDIR 내부가 아닙니다: $TABS" >&2; exit 1 ;;
  esac
  if [ ! -f "$TABS" ]; then
    echo "오류: transcript 파일이 없습니다: $TABS" >&2; exit 1
  fi

  STEM="$(basename "$TABS")"; STEM="${STEM%.txt}"

  # 도메인 정규화: NFC, 허용문자만, 길이 제한, 빈 결과 -> 미분류 (경로 탈출 불가)
  DOMAIN="$(python3 - "$DOMAIN_RAW" <<'PY'
import sys, re, unicodedata
d = unicodedata.normalize("NFC", sys.argv[1])
d = d.replace("/", " ").replace("\\", " ").replace("..", " ")
d = re.sub(r"\s+", "_", d.strip())
d = re.sub(r"[^가-힣A-Za-z0-9_-]", "", d)
d = d.strip("._-")[:30].strip("._-")
print(d or "미분류")
PY
)"

  DEST_DIR="$OUT_DIR/$DOMAIN"
  mkdir -p "$DEST_DIR"
  DEST="$DEST_DIR/$STEM.md"
  cat > "$DEST"        # stdin(요약 마크다운) -> 파일
  echo "SAVED_FILE: $DEST"
  exit 0
fi

# ──────────────────────────────────────────────────────────────────────────
# 최근 요약본 경로:  yt-script --latest   (부작용 없음)
#   OUT_DIR 안의 가장 최근 .md(_transcripts 제외) 경로를 'LATEST_FILE:' 로 출력.
#   /yt-push 가 "어떤 요약본을 올릴지" 정한 뒤 그 내용을 Read 할 때 쓴다.
# ──────────────────────────────────────────────────────────────────────────
if [ "${1:-}" = "--latest" ]; then
  ODIR="$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$OUT_DIR")"
  F="$(latest_md "$ODIR")"
  if [ -z "$F" ]; then
    echo "오류: 요약본(.md)을 찾지 못했습니다 ($ODIR)." >&2
    exit 1
  fi
  echo "LATEST_FILE: $F"
  exit 0
fi

# ──────────────────────────────────────────────────────────────────────────
# 발행 폴더 목록:  yt-script --topics   (부작용 없음)
#   발행 루트(YT_PUBLISH_DIR) 바로 아래의 기존 주제 폴더명을 출력.
#   /yt-push 가 "기존 폴더 재사용 vs 새 폴더" 를 판단할 때 쓰는 힌트.
# ──────────────────────────────────────────────────────────────────────────
if [ "${1:-}" = "--topics" ]; then
  if [ -z "${YT_PUBLISH_DIR:-}" ]; then
    echo "오류: YT_PUBLISH_DIR 가 설정돼 있지 않습니다." >&2
    exit 1
  fi
  echo "PUBLISH_ROOT: $YT_PUBLISH_DIR"
  python3 - "$YT_PUBLISH_DIR" <<'PY'
import os, sys
base = sys.argv[1]
try:
    subs = [n for n in sorted(os.listdir(base))
            if os.path.isdir(os.path.join(base, n)) and not n.startswith(".")]
except FileNotFoundError:
    subs = []
print("TOPICS: " + (", ".join(subs) if subs else "(아직 없음)"))
PY
  exit 0
fi

# ──────────────────────────────────────────────────────────────────────────
# 폴더 내 파일 목록:  yt-script --ls [topic]   (부작용 없음)
#   발행 루트(또는 그 안 [topic] 폴더)의 기존 파일명을 'FILES:' 로 출력.
#   /yt-push 가 발행 파일명을 정할 때 "작명 컨벤션 일치 / 덮어쓰기 회피" 판단에 쓴다.
# ──────────────────────────────────────────────────────────────────────────
if [ "${1:-}" = "--ls" ]; then
  if [ -z "${YT_PUBLISH_DIR:-}" ]; then
    echo "오류: YT_PUBLISH_DIR 가 설정돼 있지 않습니다." >&2
    exit 1
  fi
  LS_TOPIC="${2:-}"
  case "$LS_TOPIC" in
    */*|*..*) echo "오류: 잘못된 topic: $LS_TOPIC" >&2; exit 1 ;;
  esac
  TARGET="$YT_PUBLISH_DIR"
  [ -n "$LS_TOPIC" ] && TARGET="$YT_PUBLISH_DIR/$LS_TOPIC"
  python3 - "$TARGET" <<'PY'
import os, sys
base = sys.argv[1]
try:
    files = [n for n in sorted(os.listdir(base))
             if os.path.isfile(os.path.join(base, n)) and not n.startswith(".")]
except FileNotFoundError:
    files = []
print("FILES: " + (", ".join(files) if files else "(없음)"))
PY
  exit 0
fi

# ──────────────────────────────────────────────────────────────────────────
# 발행 모드:  yt-script --publish [summary_md] [topic] [filename]
#   저장된 요약 .md 를 발행 루트(YT_PUBLISH_DIR)의 {주제}/ 폴더로 복사·커밋·푸시한다.
#   - summary_md 생략 시: OUT_DIR 안의 가장 최근 .md(_transcripts 제외)를 자동 선택.
#   - topic(주제 폴더)·filename(깔끔한 제목)은 Claude 가 요약 내용·기존 폴더/파일
#       (--topics/--ls)을 보고 결정해 넘긴다. topic 생략 시 로컬 도메인명, filename
#       생략 시 원본 파일명으로 폴백(터미널 단독 사용 편의).
#   - 대상: $YT_PUBLISH_DIR/{정규화 topic}/{정규화 filename}.md (없는 폴더는 자동 생성).
#   - 경로/이름 안전은 --save 와 동일(정규화·경로탈출 차단). push 실패는 경고만.
# ──────────────────────────────────────────────────────────────────────────
if [ "${1:-}" = "--publish" ]; then
  if [ -z "${YT_PUBLISH_DIR:-}" ]; then
    echo "오류: YT_PUBLISH_DIR 가 설정돼 있지 않습니다." >&2
    echo "  요약본을 올릴 git repo 안의 '발행 루트' 폴더를 가리켜야 합니다. 예:" >&2
    echo "    export YT_PUBLISH_DIR=\"\$HOME/Desktop/dev-lab/study\"" >&2
    exit 1
  fi

  ODIR="$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$OUT_DIR")"
  SUMMARY="${2:-}"

  # 인자 없으면 OUT_DIR 안의 가장 최근 .md 자동 선택
  if [ -z "$SUMMARY" ]; then
    SUMMARY="$(latest_md "$ODIR")"
    if [ -z "$SUMMARY" ]; then
      echo "오류: 발행할 .md 요약본을 찾지 못했습니다 ($ODIR)." >&2
      exit 1
    fi
    echo "최근 요약본 자동 선택: $SUMMARY" >&2
  fi

  SABS="$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$SUMMARY")"
  case "$SABS" in
    "$ODIR"/_transcripts/*) echo "오류: 자막 원본(_transcripts)이 아니라 요약 .md 를 지정하세요: $SABS" >&2; exit 1 ;;
    "$ODIR"/*) : ;;
    *) echo "오류: 요약본이 $ODIR 내부가 아닙니다: $SABS" >&2; exit 1 ;;
  esac
  case "$SABS" in *.md) : ;; *) echo "오류: .md 파일이 아닙니다: $SABS" >&2; exit 1 ;; esac
  [ -f "$SABS" ] || { echo "오류: 파일이 없습니다: $SABS" >&2; exit 1; }

  # 주제 폴더 = $3 (Claude 가 내용·기존 구조 보고 결정). 생략 시 로컬 도메인 폴더명으로 폴백.
  TOPIC_RAW="${3:-}"
  [ -z "$TOPIC_RAW" ] && TOPIC_RAW="$(basename "$(dirname "$SABS")")"
  TOPIC="$(python3 - "$TOPIC_RAW" <<'PY'
import sys, re, unicodedata
d = unicodedata.normalize("NFC", sys.argv[1])
d = d.replace("/", " ").replace("\\", " ").replace("..", " ")
d = re.sub(r"\s+", "_", d.strip())
d = re.sub(r"[^가-힣A-Za-z0-9_-]", "", d)
d = d.strip("._-")[:40].strip("._-")
print(d or "미분류")
PY
)"

  # 파일명 = $4 (Claude 가 내용 보고 정한 깔끔한 제목 슬러그). 생략 시 원본 파일명 유지.
  # 공백→하이픈(kebab 스타일), 허용문자만, 확장자 .md 보장.
  FNAME_RAW="${4:-}"
  if [ -n "$FNAME_RAW" ]; then
    FNAME="$(python3 - "$FNAME_RAW" <<'PY'
import sys, re, os, unicodedata
f = unicodedata.normalize("NFC", sys.argv[1])
f = os.path.basename(f)
if f.lower().endswith(".md"):
    f = f[:-3]
f = f.replace("/", " ").replace("\\", " ").replace("..", " ")
f = re.sub(r"\s+", "-", f.strip())
f = re.sub(r"[^가-힣A-Za-z0-9._-]", "", f)
f = f.strip("._-")[:80].strip("._-")
print((f or "untitled") + ".md")
PY
)"
  else
    FNAME="$(basename "$SABS")"
  fi

  # YT_PUBLISH_DIR 가 아직 없어도 됨 — 가장 가까운 존재 상위 폴더로 git repo 인지 확인하고
  # 발행 루트·주제 폴더는 자동 생성한다.
  PROBE="$YT_PUBLISH_DIR"
  while [ ! -d "$PROBE" ] && [ "$PROBE" != "/" ] && [ "$PROBE" != "." ]; do
    PROBE="$(dirname "$PROBE")"
  done
  REPO_ROOT="$(git -C "$PROBE" rev-parse --show-toplevel 2>/dev/null || true)"
  if [ -z "$REPO_ROOT" ]; then
    echo "오류: YT_PUBLISH_DIR 가 git repo 안이 아닙니다(또는 상위 폴더 없음): $YT_PUBLISH_DIR" >&2
    echo "  대상 repo 를 먼저 git clone 하고, YT_PUBLISH_DIR 를 그 repo 안의 경로로 지정하세요." >&2
    exit 1
  fi

  DEST_DIR="$YT_PUBLISH_DIR/$TOPIC"
  mkdir -p "$DEST_DIR"
  DEST="$DEST_DIR/$FNAME"
  cp "$SABS" "$DEST"
  REL="${DEST#$REPO_ROOT/}"

  git -C "$REPO_ROOT" pull --rebase --autostash --quiet 2>/dev/null || true
  git -C "$REPO_ROOT" add "$DEST"
  if git -C "$REPO_ROOT" diff --cached --quiet; then
    echo "변경 없음(이미 동일 내용): $REL"
    exit 0
  fi
  git -C "$REPO_ROOT" commit -q -m "yt: ${TOPIC}/${FNAME} 발행" >/dev/null
  if git -C "$REPO_ROOT" push -q 2>/dev/null; then
    echo "PUSHED_FILE: $REL"
  else
    echo "경고: 커밋은 됐지만 push 실패. 네트워크/인증 확인 후 'git -C \"$REPO_ROOT\" push'." >&2
    echo "COMMITTED_FILE: $REL"
  fi
  exit 0
fi

# ──────────────────────────────────────────────────────────────────────────
# 추출 모드:  yt-script <URL> [lang]
# ──────────────────────────────────────────────────────────────────────────
URL="${1:-}"
LANG_CODE="${2:-ko}"
[ -z "$LANG_CODE" ] && LANG_CODE="ko"

if [ -z "$URL" ]; then
  echo "사용법: yt-script <유튜브 URL> [언어코드(기본 ko)]" >&2
  echo "        yt-script --save <transcript_path> <domain>   (요약 저장, stdin)" >&2
  echo "        yt-script --publish [summary_md] [topic] [filename]   (요약본을 git repo 로 발행)" >&2
  echo "        yt-script --topics | --latest | --ls [topic]   (폴더목록 / 최근요약본 / 폴더내 파일목록)" >&2
  exit 1
fi

if ! command -v yt-dlp >/dev/null 2>&1; then
  echo "오류: yt-dlp 가 설치돼 있지 않습니다." >&2
  echo "  설치:  brew install yt-dlp   (또는  pip3 install --user yt-dlp)" >&2
  exit 127
fi

CLEAN="$(resolve_clean)"
if [ ! -f "$CLEAN" ]; then
  echo "오류: ytclean.py 를 찾을 수 없습니다: $CLEAN" >&2
  echo "  → install.sh 를 다시 실행하세요(ytclean.py 심링크)." >&2
  exit 127
fi

mkdir -p "$OUT_DIR/_transcripts"
TMP="$(mktemp -d)"
trap 'rm -rf "$TMP"' EXIT

# 1) 메타데이터(제목·ID·챕터) — yt-dlp 한 번에 3줄로(네트워크 왕복 최소화). 실패해도 진행.
#    --print 순서대로 1줄=제목, 2줄=ID, 3줄=챕터JSON.
META="$(yt-dlp --no-warnings --no-playlist --skip-download \
  --print '%(title)s' --print '%(id)s' --print '%(chapters)j' \
  "$URL" 2>/dev/null || true)"
TITLE="$(printf '%s\n' "$META" | sed -n '1p')"
VID="$(printf '%s\n' "$META" | sed -n '2p')"
CHAPTERS="$(printf '%s\n' "$META" | sed -n '3p')"
[ -z "$VID" ] && VID="video"
[ -z "$TITLE" ] && TITLE="youtube_${VID}"
case "$CHAPTERS" in
  ""|"null"|"NA"|"none"|"None"|"[]") CHAPTERS="" ;;   # 챕터 없음/실패 → ytclean 평문 폴백
esac

# 2) 자막 다운로드 — 수동자막 우선, 없으면 자동자막. stderr 는 차단 진단용 로그로.
DL_LOG="$TMP/dl.log"
yt-dlp --no-warnings --no-playlist --skip-download \
  --write-subs --write-auto-subs \
  --sub-langs "${LANG_CODE},${LANG_CODE}-orig,en,en-orig" \
  --sub-format "vtt/srv3/best" \
  -o "${TMP}/sub.%(ext)s" "$URL" >/dev/null 2>"$DL_LOG" || true

# 3) 자막 파일 선택 — 요청 언어 우선순위(lang, lang-orig, en, en-orig)
SUB=""; LANG_USED=""
for L in "$LANG_CODE" "${LANG_CODE}-orig" "en" "en-orig"; do
  CAND="$(ls -1 "${TMP}/sub.${L}.vtt" 2>/dev/null | head -n1 || true)"
  if [ -n "$CAND" ]; then SUB="$CAND"; LANG_USED="$L"; break; fi
done
if [ -z "$SUB" ]; then                       # 폴백: 아무 vtt
  SUB="$(ls -1 "${TMP}"/*.vtt 2>/dev/null | head -n1 || true)"
  if [ -n "$SUB" ]; then
    LANG_USED="$(basename "$SUB")"; LANG_USED="${LANG_USED#sub.}"; LANG_USED="${LANG_USED%.vtt}"
  fi
fi
[ -z "$SUB" ] && SUB="$(ls -1 "${TMP}"/sub.* 2>/dev/null | head -n1 || true)"  # 폴백2: 비-vtt

if [ -z "$SUB" ]; then
  if grep -qiE '403|ipblock|requestblock|sign in|bot' "$DL_LOG" 2>/dev/null; then
    echo "차단/오류: 유튜브가 요청을 막았습니다(403/IpBlocked 등)." >&2
    echo "  → 'yt-dlp -U' (brew면 'brew upgrade yt-dlp') 후 잠시 뒤 재시도. 가정용 IP의 로컬 맥에서 성공률이 높습니다." >&2
    exit 3
  fi
  echo "자막 없음: 이 영상에는 ${LANG_CODE}/en 자막이 없습니다(비공개·지역제한 가능)." >&2
  echo "  → 유튜브에서 '··· → 스크립트 표시'로 직접 복사하세요." >&2
  exit 2
fi

# 4) 본문 생성(ytclean.py — VTT 정리 + 챕터 버킷팅)
BODY="$(python3 "$CLEAN" "$SUB" "$CHAPTERS")"
if printf '%s\n' "$BODY" | grep -q '^## \['; then HAS_CH="true"; else HAS_CH="false"; fi

# 5) 파일명 stem / 경로 / 기존 도메인 목록
SAFE="$(python3 - "$TITLE" <<'PY'
import sys, re
t = re.sub(r"[^\w가-힣 ._-]", "", sys.argv[1]).strip().replace(" ", "_")[:60]
print(t or "youtube")
PY
)"
DATE="$(date +%F)"
STEM="${DATE}_${SAFE}_${VID}"
OUT_PATH="$OUT_DIR/_transcripts/${STEM}.txt"

DOMAINS="$(python3 - "$OUT_DIR" <<'PY'
import os, sys
base = sys.argv[1]
try:
    subs = [n for n in sorted(os.listdir(base))
            if os.path.isdir(os.path.join(base, n)) and not n.startswith("_")]
except FileNotFoundError:
    subs = []
print(", ".join(subs))
PY
)"

SRC_URL="https://www.youtube.com/watch?v=${VID}"

# 6) 헤더(표시용 힌트) + 본문 저장
{
  echo "---"
  echo "title: ${TITLE}"
  echo "source_url: ${SRC_URL}"
  echo "date: ${DATE}"
  echo "lang_used: ${LANG_USED:-?}"
  echo "has_chapters: ${HAS_CH}"
  echo "existing_domains: ${DOMAINS}"
  echo "---"
  echo
  echo "# ${TITLE}"
  echo
  printf '%s\n' "$BODY"
} > "$OUT_PATH"

# 7) 클립보드 복사(원문 자막, best-effort)
